# Kira configuration — copy to .env and adjust. All vars optional (sane defaults).
# Local tool: no accounts, no payment, no secrets required.

# Database: SQLite by default (backend/var/rentscalper.db). For Postgres:
# RS_DATABASE_URL=postgresql+psycopg2://rentscalper:rentscalper@localhost:5432/rentscalper

# Scraping politeness / volume
# RS_REQUEST_DELAY_S=1.5
# RS_MAX_PAGES_PER_SITE=10
# RS_DETAIL_FETCH_BUDGET=40
# RS_GEOCODE_BUDGET_PER_RUN=80
# RS_SCRAPE_INTERVAL_MIN=180

# Listing freshness window (days a listing stays visible after last seen)
# RS_LISTING_ACTIVE_DAYS=4

# Parking matching
# RS_PARKING_MATCH_MAX_M=1000
# RS_PARKING_MATCHES_PER_LISTING=5

# openrouteservice API key — optional, enables real walking routes (else estimate)
# RS_ORS_API_KEY=

# CORS origins for the frontend, JSON list
# RS_CORS_ORIGINS=["http://localhost:5173"]

# ---- Abuse protection ----
# Per-IP request caps (0 = off).
# RS_GLOBAL_RATE_LIMIT_PER_MIN=600
# RS_IMG_RATE_LIMIT_PER_MIN=400
# Disk cap for the image cache; oldest files pruned past this
# RS_IMAGE_CACHE_MAX_MB=2000
