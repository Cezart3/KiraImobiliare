# RentScalper configuration — copy to .env and adjust. All vars optional (sane defaults).

# Database: SQLite by default (backend/var/rentscalper.db). For Postgres:
# RS_DATABASE_URL=postgresql+psycopg2://rentscalper:rentscalper@localhost:5432/rentscalper

# Scraping politeness / volume
# RS_REQUEST_DELAY_S=1.5
# RS_MAX_PAGES_PER_SITE=10
# RS_DETAIL_FETCH_BUDGET=40
# RS_GEOCODE_BUDGET_PER_RUN=80
# RS_SCRAPE_INTERVAL_MIN=180

# Listing freshness window (days a listing stays visible after last seen)
# RS_LISTING_ACTIVE_DAYS=4

# Parking matching
# RS_PARKING_MATCH_MAX_M=1000
# RS_PARKING_MATCHES_PER_LISTING=5

# openrouteservice API key — optional, enables real walking routes (else estimate)
# RS_ORS_API_KEY=

# Disable the open /api/admin/* endpoints in anything public...
# RS_ENABLE_ADMIN_ENDPOINTS=true
# ...and use a token instead: with the flag off, requests carrying header
# X-Admin-Token: <value> still reach /api/admin/stats (ops dashboard) + /admin/scrape
# RS_ADMIN_TOKEN=

# CORS origins for the frontend, JSON list
# RS_CORS_ORIGINS=["http://localhost:5173"]

# ---- Auth / sessions ----
# REQUIRED in production: random secret, 32+ chars (e.g. `openssl rand -hex 32`)
# RS_SECRET_KEY=
# RS_SESSION_DAYS=30
# Set true when served over HTTPS (production)
# RS_COOKIE_SECURE=false
# Google Sign-In: OAuth 2.0 Web client ID from https://console.cloud.google.com/apis/credentials
# (add your domains under "Authorized JavaScript origins"; no secret needed client-side flow)
# RS_GOOGLE_CLIENT_ID=
# RS_AUTH_RATE_LIMIT_PER_MIN=20

# ---- Abuse protection ----
# Per-IP request caps (0 = off). Endpoint-specific limits (auth, billing, img)
# apply on top of the global one.
# RS_GLOBAL_RATE_LIMIT_PER_MIN=600
# RS_IMG_RATE_LIMIT_PER_MIN=400
# Disk cap for the image cache; oldest files pruned past this
# RS_IMAGE_CACHE_MAX_MB=2000

# ---- Freemium paywall ----
# RS_PAYWALL_ENABLED=true
# How many listings anonymous/free users see (the real total is always shown)
# RS_FREE_LISTING_LIMIT=9

# ---- Stripe (abonament 15 RON/luna) ----
# 1. dashboard.stripe.com -> Product "RentScalper Plus" -> recurring price 15 RON/month
# 2. Apple Pay / Google Pay: Settings -> Payment methods -> enable Wallets
#    (production also needs domain verification under Payment method domains)
# RS_STRIPE_SECRET_KEY=sk_test_...
# RS_STRIPE_PRICE_ID=price_...
# Webhook (prod): endpoint https://<domain>/api/billing/webhook, events:
#   checkout.session.completed, customer.subscription.created/updated/deleted
# Local dev alternative: no webhook needed - the frontend calls /api/billing/sync
# RS_STRIPE_WEBHOOK_SECRET=whsec_...
# Public URL of the frontend (Stripe redirects back here)
# RS_APP_BASE_URL=http://localhost:5173
